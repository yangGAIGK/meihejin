<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.platform.magnesium_alloy_platform.mapper.BP_HistoryMapper">
    <delete id="deleteByIds">
        DELETE FROM bp_history WHERE id IN
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <select id="filterBPHistory" resultType="java.util.Map">
        SELECT *
        FROM bp_history
        WHERE 1 = 1
        <if test="uid != null and uid != ''">
            AND uid = #{uid}
        </if>
        <if test="minAveLength != null">
            AND aveLength &gt;= #{minAveLength}
        </if>
        <if test="maxAveLength != null">
            AND aveLength &lt;= #{maxAveLength}
        </if>
        <if test="minLisanValue != null">
            AND lisanValue &gt;= #{minLisanValue}
        </if>
        <if test="maxLisanValue != null">
            AND lisanValue &lt;= #{maxLisanValue}
        </if>
    </select>
</mapper>
